<?xml version="1.0" encoding="UTF-8"?>

<!-- When creating a new activity, make a copy of this file with appropriate name -->
<worksheet xml:id="poly-roots-graphs">
  <title>Graphing Polynomials from Roots</title>

  <!-- Optional introduction -->
  <introduction>
    <p>
      Solve the following problems on the graphs of polynomial functions.
    </p>
  </introduction>

  <exercise>
    <statement>
      <p>
        Let <m>f(x)=2x^2-5x+3</m>.  Factor <m>f</m> and use this to sketch a graph of <m>f</m>.
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        Let <m>f(x)=-3(x-1)(x-3)(x-4)</m>.  Use the roots of <m>f</m> along with the coefficient <m>-3</m> to sketch the graph of <m>f</m>.
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        Let <m>f(x) = k(x-a)(x-b)(x-c)(x-d)</m> with <m>a &lt; b &lt; c &lt; d</m> and <m>k &gt; 0</m>.  Sketch the graph of <m>f</m>.
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        Give a possible formula for the function whose graph is the following.
      </p>
      <image width="60%">
      	<prefigure xmlns="https://prefigure.org" label="poly-no-repeat">
          <diagram dimensions="(300, 300)" margins="5">
            <definition>f(x)=0.2*(x+1)*(x-3)*(x-5)</definition>
            <coordinates bbox="(-3,-5,8,5)">
              <axes xlabel="x" ylabel="y" hticks="(-4,1,7)" vticks="no" vlabels="no" hlabels="(-3,1,7)" />
              <graph function="f" />
              <graph function="g" domain="(-1,1)" />
              <graph function="h" domain="(1,4)" />
              <graph function="k" domain="(-4,-1)" stroke="green" />
              <graph function="m" domain="(-1,1)" stroke="green" />
              <graph function="n" domain="(1,4)" stroke="green" />
            </coordinates>
          </diagram>
        </prefigure>
      </image>
    </statement>
  </exercise>

</worksheet>