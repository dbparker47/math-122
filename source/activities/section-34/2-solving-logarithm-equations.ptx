<?xml version="1.0" encoding="UTF-8"?>

<!-- When creating a new activity, make a copy of this file with appropriate name -->
<worksheet xml:id="logarithm-equation">
  <title>Solving Logarithm Equations</title>

  <!-- Optional introduction -->
  <introduction>
    <p>
      Solve the following equations/problems.
    </p>
  </introduction>

  <exercise>
    <statement>
      <p>
        <m>3\log_4(x) = 18</m>
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        <m>5^{6x}=3</m>
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        <m>20 \cdot 6^{2x}-1=15</m>
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        (Not on quiz) Use the graph of <m>y=\left( \frac12 \right)^x</m> to draw the graph of <m>y=\log_{\frac12}(x)</m>.
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        (Not on quiz) Use the graph of <m>y=e^x</m> to draw the graph of <m>y=\ln(x)</m>.
      </p>
    </statement>
  </exercise>

</worksheet>