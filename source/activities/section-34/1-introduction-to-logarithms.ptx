<?xml version="1.0" encoding="UTF-8"?>

<!-- When creating a new activity, make a copy of this file with appropriate name -->
<worksheet xml:id="intro-logarithm">
  <title>Introduction to Logarithms</title>

  <!-- Optional introduction -->
  <introduction>
    <p>
      In the first three problems, compute the given quantity.
    </p>
  </introduction>

  <exercise>
    <statement>
      <p>
        <m>\log_3(27)</m>
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        <m>\log_2(64)</m>
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        <m>\log_{11}(121)</m>
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        Suppose <m>\log_a(x)=3</m> and <m>\log_a(y)=5</m>.
        <ol>
          <li>
            <p>
              Find an expression for <m>x</m> and <m>y</m> in terms of <m>a</m>.
            </p>
          </li>
          <li>
            <p>
              Use what you found in (a) to compute both <m>\log_a(xy)</m> and <m>\log_a \left( \frac{x}{y} \right)</m>
            </p>
          </li>
          <li>
            <p>
              Compute <m>\log_a \left( x^6 \right)</m> and <m>\log_a(y^4)</m>.
            </p>
          </li>
        </ol>
      </p>
    </statement>
  </exercise>

</worksheet>