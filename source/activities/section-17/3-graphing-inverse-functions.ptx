<?xml version="1.0" encoding="UTF-8"?>

<!-- When creating a new activity, make a copy of this file with appropriate name -->
<worksheet xml:id="graphing-inverse">
  <title>Graphing Inverse Functions</title>

  <!-- Optional introduction -->
  <introduction>
    <p>
      Graph the inverses of the following functions.
    </p>
  </introduction>

  <exercise>
    <image>
  	  <prefigure xmlns="https://prefigure.org" label="inverse-graph-1">
	      <diagram dimensions="(300,300)" margins="5">
			    <definition>f(x)= 2*sqrt(2)^x-4</definition>
    		  <coordinates bbox="(-4,-4,4,4)">
		  		  <axes xlabel="x" ylabel="y"/>
			      <graph function="f" />
  			  </coordinates>
	      </diagram>
    	</prefigure>
    </image>
  </exercise>

  <exercise>
    <image>
	    <prefigure xmlns="https://prefigure.org" label="inverse-graph-2">
		    <diagram dimensions="(300,300)" margins="5">
      		<definition>f(x)= -2*sqrt(-x-4)+2</definition>
			    <definition>g(x)= 2*sqrt(x+4)+2</definition>
      		<coordinates bbox="(-10,-10,10,10)">
			      <axes xlabel="x" ylabel="y" hticks="(-10,1,10)" vticks="(-10,1,10)" />
    				<graph function="f" domain="(-10,-4)"/>
		      	<graph function="g" domain="(-4,10)"/>
    			</coordinates>
    		</diagram>
	    </prefigure>
    </image>
  </exercise>

  <exercise>
    <statement>
      <p>
        <m>y=x^2</m> (Try)
      </p>
    </statement>
  </exercise>

</worksheet>