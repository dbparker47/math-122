<?xml version="1.0" encoding="UTF-8"?>

<!-- When creating a new activity, make a copy of this file with appropriate name -->
<worksheet xml:id="">
  <title>Composition of Functions</title>

  <!-- Optional introduction -->
  <introduction>
    <p>
      Solve the following problems on composition of functions.
    </p>
  </introduction>

  <exercise>
    <statement>
      <p>
        Find <m>f \circ g</m> and <m>g \circ f</m> for each of the following.
        <ol>
          <li>
            <p>
              <m>f(x) = 2x+3</m>, <m>g(x) = \sqrt{x^3+3x}</m>
            </p>
          </li>
          <li>
            <p>
              <m>f(x)=x^2+x</m>, <m>g(x)=\frac{x}{x+1}</m>.
            </p>
          </li>
        </ol>
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        For each of the following <m>f: \mathbb{R} \rightarrow \mathbb{R}</m>, decompose <m>f</m> into as many functions (actions) as possible.  Describe these functions both as actions and as formulas.  Also, write <m>f</m> as a composition of these functions.
        <ol>
          <li>
            <p>
              <m>f(x)=5x-6</m>
            </p>
          </li>
          <li>
            <p>
              <m>f(x) = 3x^3+11</m>
            </p>
          </li>
          <li>
            <p>
              <m>f(x) = \sqrt{\frac{x^2+1}{5}}</m>
            </p>
          </li>
        </ol>
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        Consider the graphs for functions <m>p</m> and <m>q</m>.
      </p>
      Image here.
      <p>
        <ol>
          <li>
            <p>
              Pick some integer values of <m>x</m> and compute <m>p(q(x))</m>.
            </p>
          </li>
          <li>
            <p>
              Pick some integer values of <m>x</m> and compute <m>q(p(x))</m>.
            </p>
          </li>
        </ol>
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        Find <m>f \circ g</m> for the functions <m>f: \{ -3,-1,1,2,3,5 \} \rightarrow \{3,7,9,10 \}</m> and <m>g: \{ 1,2,4,5,6,10 \} \rightarrow \{ -3,1,2,3,5 \}</m> given by
        <md>f = \{(1,3),(5,7),(2,3),(3,9),(-1,7),(-3,10)\}</md>
        <md>g=\{(5,2),(1,3),(4,1),(6,-3),(2,1),(10,5)\}</md>
      </p>
    </statement>
  </exercise>

</worksheet>