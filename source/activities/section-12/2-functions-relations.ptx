<?xml version="1.0" encoding="UTF-8"?>

<!-- When creating a new activity, make a copy of this file with appropriate name -->
<worksheet xml:id="functions-relations">
  <title>Functions &amp; Relations</title>

  <!-- Optional introduction -->
  <introduction>
    <p>
      For each of the following relations, determine if it is a function.  Note that if the variables are <m>x</m> and <m>y</m>, then <m>x</m> is the input and <m>y</m> is the output.
    </p>
  </introduction>

  <exercise>
    <statement>
      <tabular halign="right">
        <row>
          <cell bottom="minor" right="minor"><m>x</m></cell>
          <cell bottom="minor" right="minor"><m>1</m></cell>
          <cell bottom="minor" right="minor">2</cell>
          <cell bottom="minor" right="minor">3</cell>
          <cell bottom="minor" right="minor">4</cell>
          <cell bottom="minor" right="minor">5</cell>
          <cell bottom="minor" right="minor">6</cell>
          <cell bottom="minor">7</cell>
        </row>
        <row>
          <cell right="minor"><m>f(x)</m></cell>
          <cell right="minor"><m>-2</m></cell>
          <cell right="minor">5</cell>
          <cell right="minor"><m>-1</m></cell>
          <cell right="minor">0</cell>
          <cell right="minor">3</cell>
          <cell right="minor">5</cell>
          <cell>1</cell>
        </row>
      </tabular>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <tabular halign="right">
        <row>
          <cell bottom="minor" right="minor"><m>x</m></cell>
          <cell bottom="minor" right="minor"><m>1</m></cell>
          <cell bottom="minor" right="minor">2</cell>
          <cell bottom="minor" right="minor">3</cell>
          <cell bottom="minor" right="minor">4</cell>
          <cell bottom="minor" right="minor">2</cell>
          <cell bottom="minor" right="minor">6</cell>
          <cell bottom="minor">7</cell>
        </row>
        <row>
          <cell right="minor"><m>f(x)</m></cell>
          <cell right="minor"><m>-2</m></cell>
          <cell right="minor">5</cell>
          <cell right="minor"><m>-1</m></cell>
          <cell right="minor">0</cell>
          <cell right="minor">3</cell>
          <cell right="minor">4</cell>
          <cell>1</cell>
        </row>
      </tabular>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        <m>x+y^2=4</m>
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        <m>x^2+y=4</m>
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        Image here.
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        Image here.
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        One of the relations in #3 and #4 is a function, and one is not a function.
        <ol>
            <li>
                <p>
                    For the relation that is a function, find a formula for the function.
                </p>
            </li>
            <li>
                <p>
                    For the relation that is not a function, show how trying to solve for the formula of the function shows that it is not a function.
                </p>
            </li>
        </ol>
      </p>
    </statement>
  </exercise>

</worksheet>